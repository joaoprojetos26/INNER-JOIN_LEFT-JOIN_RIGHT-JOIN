SELECT Orders.OrderID AS IDPedido,
Orders.OrderDate AS Data_Pedido,
Shippers.ShipperName AS transportadora
FROM Orders
INNER JOIN Shippers
    ON Orders.ShipperID = Shippers.ShipperID ;

