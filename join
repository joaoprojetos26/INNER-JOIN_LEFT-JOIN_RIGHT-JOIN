at10
SELECT Shippers.ShipperName,
       COUNT(Orders.Cod_Order) AS TotalPedidos
FROM Shippers
LEFT JOIN Orders
    ON Shippers.Cod_Shipper = Orders.Cod_Shipper
GROUP BY Shippers.Cod_Shipper, Shippers.ShipperName
ORDER BY Shippers.ShipperName ASC;

