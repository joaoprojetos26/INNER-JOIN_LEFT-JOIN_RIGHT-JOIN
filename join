AT1
SELECT 
    Products.ProductName AS NomeProduto,
    Suppliers.SupplierName AS NomeFornecedor,
    Suppliers.Country AS PaisFornecedor
FROM Products
INNER JOIN Suppliers
    ON Products.SupplierID = Suppliers.SupplierID
WHERE Products.CategoryID = 2;

at2
SELECT Orders.OrderID AS IDPedido,
Orders.OrderDate AS Data_Pedido,
Shippers.ShipperName AS transportadora
FROM Orders
INNER JOIN Shippers
    ON Orders.ShipperID = Shippers.ShipperID ;

at3
SELECT Products.ProductName AS NomeDoProduto,
Products.Price AS 'Precos Maior Que 50.00',
Suppliers.City AS Cidade
FROM Products  
INNER JOIN Suppliers 
    ON Products.SupplierID = Suppliers.SupplierID
    WHERE Products.Price>50 ;

at4
SELECT Orders.OrderID AS IDPedido,
Shippers.ShipperName AS NomeTransportadora
FROM Orders
INNER JOIN Shippers
ON Orders.ShipperID = Shippers.ShipperID
WHERE ShipperName LIKE 'Speedy Express';

at5
SELECT Products.ProductName AS NomeDoProduto,
Suppliers.SupplierName AS NomeDoFornecedor
FROM Products
INNER JOIN Suppliers
ON Products .SupplierID = Suppliers.SupplierID
WHERE Suppliers.Country IN ('USA','BRAZIL');

at6
SELECT Orders.OrderID,
Orders.OrderDate,
Shippers.Phone
FROM Orders
INNER JOIN Shippers
ON Orders.ShipperID = Shippers.ShipperID
WHERE Orders.OrderDate LIKE 2023;
